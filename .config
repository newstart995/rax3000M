# 1. 硬件机型定义 (必须)
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_jdcloud_rax3000m=y

# 2. 基础系统与中文界面
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-theme-argon=y

# 3. iStore 软件中心 (如果你的源码集成了 iStore feeds)
CONFIG_PACKAGE_luci-app-istore=y
CONFIG_PACKAGE_luci-i18n-istore-zh-cn=y

# 4. 算力版 eMMC 存储支持 (发挥 64G 优势)
CONFIG_PACKAGE_kmod-mmc=y
CONFIG_PACKAGE_kmod-sdhci-mtk=y
CONFIG_PACKAGE_fdisk=y
CONFIG_PACKAGE_block-mount=y

# 5. 常用必备插件 (根据需求增删)
CONFIG_PACKAGE_luci-app-upnp=y              # UPnP 自动端口转发
CONFIG_PACKAGE_luci-app-ttyd=y              # 网页终端
CONFIG_PACKAGE_luci-app-diskman=y           # 磁盘管理工具
CONFIG_PACKAGE_luci-app-docker=y            # Docker 容器支持 (算力版核心玩法)

# 6. 网络加速与工具
CONFIG_PACKAGE_luci-app-turboacc=y          # 流量加速 (BBR/HW NAT)
CONFIG_PACKAGE_luci-app-arpbind=y           # IP/MAC 绑定
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_htop=y                       # 命令行资源监控
